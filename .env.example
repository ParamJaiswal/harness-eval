# ============================================================
# AI Eval Harness — Environment Variable Reference
# Copy this file to .env and fill in your values.
# ============================================================

# --- Server ---
EVAL_HARNESS_PORT=8000
EVAL_HARNESS_ENV=production          # development | production
EVAL_HARNESS_LOG_LEVEL=INFO          # DEBUG | INFO | WARNING | ERROR

# --- Database ---
# Option A: Short path (SQLite) — used in Docker deployments
EVAL_HARNESS_DB_PATH=/app/data/evalharness.db

# Option B: Full SQLAlchemy async URL — overrides DB_PATH if set
# EVAL_HARNESS_DATABASE_URL=sqlite+aiosqlite:///./evalharness.db

# --- Authentication ---
# Set to enforce Bearer-token auth on all /api/* endpoints.
# Leave empty to disable authentication.
EVAL_HARNESS_API_KEY=

# --- CORS ---
# Comma-separated list of allowed origins, or * for all.
EVAL_HARNESS_CORS_ORIGINS=*

# --- Provider API Keys ---
# Required only when using real LLM providers (not mock adapters)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Evaluation Engine ---
EVAL_HARNESS_DEFAULT_CONCURRENCY=5  # Parallel tasks per run
EVAL_HARNESS_EVAL_RUNS_PER_TASK=3   # Runs per task (for statistical averaging)
EVAL_HARNESS_DEFAULT_TIMEOUT=60     # Seconds before a single task times out
EVAL_HARNESS_MAX_WORKERS=4          # uvicorn worker processes (Docker)
EVAL_HARNESS_RATE_LIMIT=100         # API rate limit (requests per minute)
